{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "app/accountant/page.jsx",
    "app/admin/page.jsx",
    "app/diet-clerk/page.jsx",
    "app/forgot-password/page.jsx",
    "app/kitchen/page.jsx",
    "app/login/page.jsx",
    "app/reset-password/loading.jsx",
    "app/reset-password/page.jsx",
    "app/subject-clerk/page.jsx",
    "app/layout.jsx",
    "app/page.jsx",
    "components/admin/diet-cycle-tab.jsx",
    "components/admin/diet-types-tab.jsx",
    "components/admin/ingredient-requirements-tab.jsx",
    "components/admin/ingredients-tab.jsx",
    "components/admin/recipes-tab.jsx",
    "components/admin/system-settings-tab.jsx",
    "components/admin/user-accounts-tab.jsx",
    "components/admin/wards-tab.jsx",
    "components/subject-clerk/order-revision-tab.jsx",
    "components/subject-clerk/pricing-tab.jsx",
    "components/ui/accordion.jsx",
    "components/ui/alert-dialog.jsx",
    "components/ui/alert.jsx",
    "components/ui/aspect-ratio.jsx",
    "components/ui/avatar.jsx",
    "components/ui/badge.jsx",
    "components/ui/breadcrumb.jsx",
    "components/ui/button.jsx",
    "components/ui/calendar.jsx",
    "components/ui/card.jsx",
    "components/ui/carousel.jsx",
    "components/ui/chart.jsx",
    "components/ui/checkbox.jsx",
    "components/ui/collapsible.jsx",
    "components/ui/command.jsx",
    "components/ui/context-menu.jsx",
    "components/ui/dialog.jsx",
    "components/ui/drawer.jsx",
    "components/ui/dropdown-menu.jsx",
    "components/ui/form.jsx",
    "components/ui/hover-card.jsx",
    "components/ui/input-otp.jsx",
